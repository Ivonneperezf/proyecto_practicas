<launch>
  <arg name="paused" default="true"/>
  <arg name="use_sim_time" default="true"/>
  <arg name="gui" default="true"/>
  <arg name="headless" default="false"/>
  <arg name="debug" default="false"/>
  <arg name="use_trajectory_controller" default="true"/>
  <arg name="world" default="world_table_bowl_with_apple"/>

  <param name="robot_type" value="m1n6s300"/>
  <param name="robot_connected" value="false"/>
  <param name="/pick_place_demo/arm/solve_type" value="Manipulation2"/>
  <param name="/pick_place_demo/arm/kinematics_solver_timeout" value="0.05"/>

  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name" value="$(find sim_kinova)/worlds/$(arg world).world"/>
    <arg name="debug" value="$(arg debug)"/>
    <arg name="gui" value="$(arg gui)"/>
    <arg name="paused" value="$(arg paused)"/>
    <arg name="use_sim_time" value="$(arg use_sim_time)"/>
    <arg name="headless" value="$(arg headless)"/>
  </include>

  <param name="robot_description"
    command="$(find xacro)/xacro --inorder '$(find kinova_description)/urdf/m1n6s300_standalone.xacro'"/>

  <node name="urdf_spawner" pkg="gazebo_ros" type="spawn_model" respawn="false" output="screen"
    args="-urdf -model m1n6s300 -param robot_description
          -z 1.015
          -J m1n6s300_joint_1 0.0
          -J m1n6s300_joint_2 2.9
          -J m1n6s300_joint_3 1.3
          -J m1n6s300_joint_4 -2.07
          -J m1n6s300_joint_5 1.4
          -J m1n6s300_joint_6 0.0
          -J m1n6s300_joint_finger_1 1.0
          -J m1n6s300_joint_finger_2 1.0
          -J m1n6s300_joint_finger_3 1.0"/>

  <include file="$(find kinova_control)/launch/kinova_control.launch">
    <arg name="kinova_robotName" value="m1n6s300"/>
    <arg name="kinova_robotType" value="m1n6s300"/>
    <arg name="use_trajectory_controller" value="$(arg use_trajectory_controller)"/>
    <arg name="is7dof" value="false"/>
    <arg name="has2finger" value="false"/>
    <arg name="description_name" value="robot_description"/>
  </include>

  <include file="$(find m1n6s300_moveit_config)/launch/planning_context.launch">
    <arg name="load_robot_description" value="false"/>
  </include>

  <rosparam file="$(find m1n6s300_moveit_config)/config/controllers_ros_control.yaml"/>

  <include file="$(find m1n6s300_moveit_config)/launch/move_group_m1n6s300.launch">
    <arg name="allow_trajectory_execution" value="true"/>
    <arg name="fake_execution" value="false"/>
    <arg name="info" value="true"/>
    <arg name="debug" value="$(arg debug)"/>
    <arg name="joint_states_ns" value="/m1n6s300/joint_states"/>
    <arg name="controller_manager" value="m1n6s300_ros_control"/>
    <arg name="gazebo_sim" value="true"/>
  </include>

</launch>